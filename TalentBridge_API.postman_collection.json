{
  "info": {
    "name": "TalentBridge Job Portal API",
    "description": "Complete API collection for the TalentBridge Job Portal",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api", "type": "string" },
    { "key": "token",   "value": "", "type": "string" },
    { "key": "jobId",   "value": "", "type": "string" },
    { "key": "appId",   "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register - Job Seeker",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Jane Smith\",\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\",\n  \"role\": \"jobseeker\"\n}"
            }
          }
        },
        {
          "name": "Register - Recruiter",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Bob Recruiter\",\n  \"email\": \"bob@company.com\",\n  \"password\": \"password123\",\n  \"role\": \"recruiter\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.token) pm.collectionVariables.set('token', res.token);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"jane@example.com\",\n  \"password\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Jobs",
      "item": [
        {
          "name": "Get All Jobs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/jobs?page=1&limit=10",
              "query": [
                { "key": "page",       "value": "1" },
                { "key": "limit",      "value": "10" },
                { "key": "search",     "value": "",    "disabled": true },
                { "key": "location",   "value": "",    "disabled": true },
                { "key": "jobType",    "value": "",    "disabled": true },
                { "key": "experience", "value": "",    "disabled": true },
                { "key": "salaryMin",  "value": "",    "disabled": true },
                { "key": "salaryMax",  "value": "",    "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Job by ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Create Job (Recruiter)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.job) pm.collectionVariables.set('jobId', res.job._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/jobs",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Senior React Developer\",\n  \"description\": \"We are looking for an experienced React developer...\",\n  \"company\": \"TechCorp Inc\",\n  \"location\": \"San Francisco, CA\",\n  \"jobType\": \"Full-time\",\n  \"experience\": \"Senior\",\n  \"salary\": {\"min\": 120000, \"max\": 180000, \"currency\": \"USD\", \"period\": \"yearly\"},\n  \"skills\": [\"React\", \"TypeScript\", \"Node.js\", \"GraphQL\"],\n  \"responsibilities\": [\"Build and maintain frontend applications\", \"Collaborate with design team\"],\n  \"requirements\": [\"5+ years React experience\", \"Strong TypeScript skills\"],\n  \"benefits\": [\"Health insurance\", \"Remote work\", \"401k matching\"]\n}"
            }
          }
        },
        {
          "name": "Update Job (Recruiter)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/jobs/{{jobId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Lead React Developer\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Delete Job (Recruiter)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/{{jobId}}"
          }
        },
        {
          "name": "Get My Jobs (Recruiter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/jobs/my-jobs"
          }
        }
      ]
    },
    {
      "name": "Applications",
      "item": [
        {
          "name": "Apply to Job (Job Seeker)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.application) pm.collectionVariables.set('appId', res.application._id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/apply/{{jobId}}",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "coverLetter", "value": "I am very excited about this role and believe my experience aligns perfectly with your requirements...", "type": "text" }
              ]
            }
          }
        },
        {
          "name": "Get My Applications (Job Seeker)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/my-applications"
          }
        },
        {
          "name": "Get Job Applications (Recruiter)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/job/{{jobId}}"
          }
        },
        {
          "name": "Update Application Status (Recruiter)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/applications/{{appId}}/status",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"shortlisted\",\n  \"recruiterNotes\": \"Strong candidate, schedule technical interview\"\n}"
            }
          }
        },
        {
          "name": "Recruiter Analytics",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/analytics"
          }
        },
        {
          "name": "Withdraw Application (Job Seeker)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/applications/{{appId}}"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/profile/me"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type",  "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/profile/me",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"headline\": \"Senior Full-Stack Developer | React & Node.js\",\n  \"bio\": \"Passionate developer with 5+ years of experience...\",\n  \"phone\": \"+1-555-123-4567\",\n  \"location\": \"San Francisco, CA\",\n  \"website\": \"https://johndoe.dev\",\n  \"linkedin\": \"https://linkedin.com/in/johndoe\",\n  \"github\": \"https://github.com/johndoe\",\n  \"skills\": [\"React\", \"Node.js\", \"TypeScript\", \"MongoDB\", \"GraphQL\"]\n}"
            }
          }
        },
        {
          "name": "Get Profile by User ID",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/profile/USER_ID_HERE"
          }
        }
      ]
    },
    {
      "name": "Users (Admin)",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{baseUrl}}/users?page=1&limit=20",
              "query": [
                { "key": "page",   "value": "1" },
                { "key": "limit",  "value": "20" },
                { "key": "role",   "value": "", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Platform Stats (Admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/stats"
          }
        },
        {
          "name": "Toggle User Status (Admin)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/USER_ID_HERE/toggle-status"
          }
        },
        {
          "name": "Delete User (Admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/USER_ID_HERE"
          }
        },
        {
          "name": "Bookmark a Job",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/bookmark/{{jobId}}"
          }
        },
        {
          "name": "Get Bookmarks",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/users/bookmarks"
          }
        }
      ]
    }
  ]
}
